{
  "package_id": "com.blastedstudios.monocle",
  "edition": "202601",
  "name": "monocle",
  "version": "0.1.0",
  "description": "Matrix messaging from your G2 glasses",
  "min_app_version": "2.0.0",
  "min_sdk_version": "0.0.10",
  "entrypoint": "index.html",
  "permissions": [
    {
      "name": "network",
      "desc": "Connects to local monocle orchestrator for Matrix messaging",
      "whitelist": [
        "http://localhost:4000",
        "ws://localhost:4000"
      ]
    },
    {
      "name": "g2-microphone",
      "desc": "Voice input for composing messages"
    }
  ],
  "supported_languages": ["en"]
}
